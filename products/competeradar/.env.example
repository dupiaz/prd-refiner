# =============================================================
# CompeteRadar — Environment Variables Template
# Copy to .env.local and fill in values
# =============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Database (Supabase) ─────────────────────────────────────
# Option A: Supabase Cloud (recommended for dev)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Option B: Local Docker Postgres (for offline / testing)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/competeradar_dev
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=competeradar_dev
# DB_PORT=5432

# ── Auth (Better Auth) ──────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-random-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── AI / LLM ────────────────────────────────────────────────
GOOGLE_AI_API_KEY=
# Optional: multi-provider gateway
# PORTKEY_API_KEY=
# LITELLM_API_URL=

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_...

# ── Inngest (Job Queue) ─────────────────────────────────────
INNGEST_SIGNING_KEY=
INNGEST_EVENT_KEY=

# ── Analytics (PostHog) ─────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── BYOK Encryption ─────────────────────────────────────────
BYOK_ENCRYPTION_KEY=change-me-to-random-32-chars
